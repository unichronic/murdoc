digraph MurdocFlow {
  rankdir=LR;
  splines=true;
  nodesep=0.5;
  ranksep=0.9;
  fontname="Helvetica";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8fafc", color="#475569"];
  edge [fontname="Helvetica", fontsize=10, color="#64748b"];

  user [label="Agent / App Client", fillcolor="#dbeafe"];
  dashboard [label="React Dashboard\n/ui/dist", fillcolor="#dbeafe"];
  gateway [label="Murdoc HTTP Gateway\nmurdoc/gateway/app.py", fillcolor="#bfdbfe"];
  openai [label="OpenAI-Compatible LLM Gateway\n/v1/chat/completions", fillcolor="#dbeafe"];
  httpproxy [label="HTTP Tool/API Gateway\n/proxy/{route_id}/...", fillcolor="#dbeafe"];
  mcp [label="MCP Gateway\nmurdoc/mcp/proxy_server.py", fillcolor="#dbeafe"];
  runtime [label="Murdoc Runtime Core\nmurdoc/core/runtime.py", fillcolor="#bfdbfe"];
  control [label="Lightweight Control Plane\nroute registry + profiles + versions", fillcolor="#e0e7ff"];
  ledger [label="Decision Ledger\nhashes, verdicts, versions, latency", fillcolor="#e0e7ff"];

  lakera [label="Lakera Guard\nprompt attack scan", fillcolor="#fde68a"];
  nemo [label="NeMo Guardrails\nsemantic input rails", fillcolor="#fde68a"];
  presidio_in [label="Presidio Input\nPII detect + redact", fillcolor="#fde68a"];
  policy [label="OPA-compatible Policy Engine\nmurdoc/security/policy_engine.py", fillcolor="#fde68a"];
  sanitize [label="Context Sanitization\nfor backend execution", fillcolor="#fde68a"];
  backend [label="Agent / Tool / API Backend\nregistered upstream URL", fillcolor="#c7d2fe"];
  model [label="OpenAI-Compatible Model Provider\nregistered upstream URL", fillcolor="#c7d2fe"];
  mcpdownstream [label="Downstream MCP Server\nstdio command", fillcolor="#c7d2fe"];
  memory [label="Persisted Memory Context\nAGENT_MEMORY_CONTEXT_URL", fillcolor="#c7d2fe"];
  presidio_out [label="Presidio Output\nPII detect + redact", fillcolor="#fde68a"];
  response [label="Gateway Response", fillcolor="#dbeafe"];

  observability [label="Observability\nPrometheus + OTEL + event log", fillcolor="#dcfce7"];
  otel [label="OTLP Collector / Grafana stack\noptional", fillcolor="#dcfce7"];

  subgraph cluster_tools {
    label="Target tools and multi-agent audit surfaces";
    color="#cbd5e1";
    style="rounded";
    crm [label="CRM DB"];
    email [label="Email log"];
    tickets [label="Ticket log"];
    shell [label="Shell log"];
    http [label="HTTP/Webhook log"];
    peer [label="Peer-agent log"];
    a2a [label="A2A inbound/outbound log"];
    peeragent [label="Live peer agent\n/a2a/message", fillcolor="#c7d2fe"];
    agnoteam [label="Agno Team target\nTeam(mode=route)", fillcolor="#c7d2fe"];
  }

  subgraph cluster_testing {
    label="Adversarial testing path";
    color="#cbd5e1";
    style="rounded";
    fuzz [label="attack_lab.py / agent_fuzzer.py", fillcolor="#fee2e2"];
    raw [label="Raw vulnerable target\nbypass gateway", fillcolor="#fecaca"];
    cisco [label="Cisco A2A Scanner\ncard + endpoint checks", fillcolor="#fee2e2"];
  }

  dashboard -> gateway [label="/api/control-plane"];
  user -> openai [label="LLM calls"];
  user -> httpproxy [label="tool/API calls"];
  user -> mcp [label="MCP tool calls"];
  openai -> gateway;
  httpproxy -> gateway;
  mcp -> runtime [label="adapt MCP request"];
  gateway -> runtime [label="adapt HTTP request"];
  gateway -> control [label="management API"];
  control -> runtime [label="local config snapshot"];
  memory -> runtime [label="load memory contexts"];
  runtime -> lakera [label="1. scan_prompt(text)"];
  runtime -> nemo [label="2. scan_semantics(text)"];
  runtime -> presidio_in [label="3. scan/redact input"];
  runtime -> policy [label="4. build signals + evaluate"];
  policy -> sanitize [label="allow path"];
  sanitize -> backend [label="authorized tool/API call"];
  sanitize -> model [label="authorized LLM call"];
  sanitize -> mcpdownstream [label="authorized MCP call"];
  backend -> crm;
  backend -> email;
  backend -> tickets;
  backend -> shell;
  backend -> http;
  backend -> peer;
  backend -> peeragent [label="optional live delegation"];
  backend -> agnoteam [label="optional Agno team route"];
  peeragent -> a2a;
  peeragent -> crm;
  peeragent -> email;
  agnoteam -> peer;
  agnoteam -> a2a;
  agnoteam -> crm;
  agnoteam -> email;
  backend -> runtime [label="tool calls + response"];
  runtime -> presidio_out [label="5. scan/redact output"];
  presidio_out -> response;
  response -> user;
  response -> dashboard;

  runtime -> observability [label="security events"];
  runtime -> ledger [label="final decision record"];
  gateway -> observability [label="HTTP metrics, traces"];
  observability -> otel [label="OTLP export / Prometheus scrape"];

  fuzz -> gateway [label="guarded attacks"];
  fuzz -> raw [label="unguarded attacks"];
  fuzz -> cisco [label="multi-agent target scan"];
  cisco -> backend [label="agent card + endpoint"];
  cisco -> agnoteam [label="agent card + endpoint"];
  raw -> backend [label="direct process()"];
}
