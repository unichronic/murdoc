# AgentVault gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
AGENT_BACKEND_URL=
AGENT_MEMORY_CONTEXT_URL=
AGENT_BACKEND_TIMEOUT=10

# Lakera Guard
# Set LAKERA_REQUIRED=true in environments where prompt-injection scanning
# must fail closed if Lakera is unavailable.
# For production tuning, create a dedicated Lakera project/policy per
# integration and supply its project ID here.
LAKERA_REQUIRED=false
LAKERA_API_KEY=
LAKERA_API_URL=https://api.lakera.ai
LAKERA_CONFIDENCE_THRESHOLD=0.8
LAKERA_PROJECT_ID=
LAKERA_BREAKDOWN=false

# NeMo Guardrails semantic layer
# Enable only after installing nemoguardrails and configuring access to models.
# The default in-repo rail uses self-check input for agent-security semantics.
# Keep ENFORCE=false until you have measured benign false positives.
NEMO_GUARDRAILS_ENABLED=false
NEMO_GUARDRAILS_REQUIRED=false
NEMO_GUARDRAILS_ENFORCE=false
NEMO_GUARDRAILS_MAX_CONCURRENCY=1
NEMO_GUARDRAILS_SKIP_LOW_RISK_READS=true
NEMO_GUARDRAILS_CONFIG_PATH=
NEMO_GUARDRAILS_MAIN_MODEL=meta/llama-3.3-70b-instruct
NEMO_GUARDRAILS_CONTENT_SAFETY_MODEL=nvidia/llama-3.1-nemoguard-8b-content-safety

# Presidio
PRESIDIO_SCORE_THRESHOLD=0.3
PRESIDIO_ENTITIES=CREDIT_CARD,EMAIL_ADDRESS,PHONE_NUMBER,US_SSN,IP_ADDRESS,IBAN_CODE,CRYPTO,US_PASSPORT,US_DRIVER_LICENSE,US_BANK_NUMBER

# Policy engine / OPA
# Leave OPA_POLICY_URL empty to use the local OPA-compatible evaluator.
OPA_POLICY_URL=http://127.0.0.1:8181/v1/data/agentvault/decision
OPA_TIMEOUT_SECONDS=1.0
OPA_FAIL_CLOSED=true

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OBSERVABILITY_EVENT_LOG_FILE=logs/agentvault-events.jsonl

# Local attack lab
# Leave false for deterministic local regression runs. Set true or use
# `python3 tools/attack_lab.py --real-services ...` to run against real
# Lakera/NeMo/OPA configuration from the ambient environment.
AGENTVAULT_USE_REAL_SERVICES=false
AGENTVAULT_STRICT_REAL_SERVICES=true
AGENTVAULT_GATEWAY_URL=http://localhost:8000/api/process
AGENTVAULT_AGENT_URL=http://localhost:8001/process
AGENTVAULT_AUDIT_URL=http://localhost:8001/audit
AGENTVAULT_RESET_URL=http://localhost:8001/reset
AGENTVAULT_REQUEST_TIMEOUT=15

# Optional MCP / demo integrations
NOTION_TOKEN=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
