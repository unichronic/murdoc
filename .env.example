# Murdoc gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
MURDOC_ADMIN_TOKEN=
AGENT_BACKEND_URL=
AGENT_MEMORY_CONTEXT_URL=
AGENT_BACKEND_TIMEOUT=10
MURDOC_READ_CACHE_ENABLED=true
MURDOC_READ_CACHE_MAX_ITEMS=256
MURDOC_READ_CACHE_TTL_SECONDS=300
MURDOC_CONTROL_PLANE_FILE=
MURDOC_GATEWAY_ROUTES_FILE=
MURDOC_RUNTIME_SETTINGS_FILE=
MURDOC_DECISION_LEDGER_FILE=

# Lakera Guard
LAKERA_API_KEY=
LAKERA_API_URL=https://api.lakera.ai
LAKERA_PROJECT_ID=

# NeMo Guardrails semantic layer
NEMO_GUARDRAILS_MAX_CONCURRENCY=1
NEMO_GUARDRAILS_CONFIG_PATH=
NEMO_GUARDRAILS_MAIN_MODEL=meta/llama-3.3-70b-instruct
NEMO_GUARDRAILS_CONTENT_SAFETY_MODEL=nvidia/llama-3.1-nemoguard-8b-content-safety

# Presidio
PRESIDIO_SCORE_THRESHOLD=0.3
PRESIDIO_ENTITIES=CREDIT_CARD,EMAIL_ADDRESS,PHONE_NUMBER,US_SSN,IP_ADDRESS,IBAN_CODE,CRYPTO,US_PASSPORT,US_DRIVER_LICENSE,US_BANK_NUMBER

# Policy engine / OPA
# Leave OPA_POLICY_URL empty to use the local OPA-compatible evaluator.
OPA_POLICY_URL=http://127.0.0.1:8181/v1/data/murdoc/decision
OPA_TIMEOUT_SECONDS=1.0

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OBSERVABILITY_EVENT_LOG_FILE=logs/murdoc-events.jsonl

# Local attack lab
# Leave false for deterministic local regression runs. Set true or use
# `python3 tools/attack_lab.py --real-services ...` to run against real
# Lakera/NeMo/OPA configuration from the ambient environment.
MURDOC_USE_REAL_SERVICES=false
MURDOC_STRICT_REAL_SERVICES=true
MURDOC_GATEWAY_URL=http://localhost:8000/api/process
MURDOC_AGENT_URL=http://localhost:8001/process
MURDOC_AUDIT_URL=http://localhost:8001/audit
MURDOC_RESET_URL=http://localhost:8001/reset
MURDOC_REQUEST_TIMEOUT=15

# Optional MCP / demo integrations
NOTION_TOKEN=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
