# Copy this file to .env and fill in local demo values.

NOTION_TOKEN=ntn_****

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Tool names can be bare names or server-qualified values like notion:notion-search.
# Empty allow/block lists default to exposing all tools, then Murdoc still checks
# every tool call before execution.
MCP_SERVER_ID=notion
MCP_ALLOWED_TOOLS=
MCP_BLOCKED_TOOLS=
MCP_ENFORCE_TOOL_ALLOWLIST=false
MCP_READ_ONLY_MODE=false
MCP_TENANT_ID=default
MCP_USER_ID=

NOTION_MCP_TRANSPORT=stdio

# When running `python -m murdoc_mcp.proxy_server`, Murdoc exposes an MCP
# server to upstream clients and connects to this downstream MCP server.
MCP_DOWNSTREAM_COMMAND=npx
MCP_DOWNSTREAM_ARGS=-y @notionhq/notion-mcp-server

NOTION_MCP_HTTP_PORT=3001
NOTION_MCP_AUTH_TOKEN=your-secret-auth-token
