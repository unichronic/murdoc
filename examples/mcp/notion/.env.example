# ============================================================
# MCP Gateway - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# --- Notion Integration ---
# Get your token from: https://www.notion.so/profile/integrations
NOTION_TOKEN=ntn_****

# --- Gemini API Key (for the AI client) ---
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Gemini Model ---
GEMINI_MODEL=gemini-2.0-flash

# --- Bifrost Gateway ---
# Optional URL for future external proxy mode. The current clients use the
# in-process Bifrost MCP interceptor before every tool call.
BIFROST_GATEWAY_URL=http://localhost:8080

# --- MCP Tool Security ---
# Tool names can be bare names or server-qualified values like notion:notion-search.
# Empty allow/block lists default to exposing all tools, then Bifrost still checks
# every tool call before execution.
MCP_SERVER_ID=notion
MCP_ALLOWED_TOOLS=
MCP_BLOCKED_TOOLS=
MCP_ENFORCE_TOOL_ALLOWLIST=false
MCP_READ_ONLY_MODE=false
MCP_TENANT_ID=default
MCP_USER_ID=

# --- Notion MCP Server Transport ---
# Options: "stdio" or "http"
NOTION_MCP_TRANSPORT=stdio

# --- Standalone MCP Proxy Mode ---
# When running `python -m mcp_gateway.proxy_server`, AgentVault exposes an MCP
# server to upstream clients and connects to this downstream MCP server.
MCP_DOWNSTREAM_COMMAND=npx
MCP_DOWNSTREAM_ARGS=-y @notionhq/notion-mcp-server

# --- Notion MCP HTTP Transport Settings (only if using http transport) ---
NOTION_MCP_HTTP_PORT=3001
NOTION_MCP_AUTH_TOKEN=your-secret-auth-token
