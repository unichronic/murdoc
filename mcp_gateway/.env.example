# ============================================================
# MCP Gateway - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# --- Notion Integration ---
# Get your token from: https://www.notion.so/profile/integrations
NOTION_TOKEN=ntn_****

# --- Gemini API Key (for the AI client) ---
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Gemini Model ---
GEMINI_MODEL=gemini-2.0-flash

# --- Bifrost Gateway ---
# URL where the Bifrost Gateway is running
BIFROST_GATEWAY_URL=http://localhost:8080

# --- Notion MCP Server Transport ---
# Options: "stdio" or "http"
NOTION_MCP_TRANSPORT=stdio

# --- Notion MCP HTTP Transport Settings (only if using http transport) ---
NOTION_MCP_HTTP_PORT=3001
NOTION_MCP_AUTH_TOKEN=your-secret-auth-token
